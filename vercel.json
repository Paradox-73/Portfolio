{
    "version": 2,
    "builds": [
        {
            "src": "client/**/*",
            "use": "@vercel/static"
        },
        {
            "src": "api/server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "client/$1"
        }
    ],
    "crons": [
        {
            "path": "/api/sync-letterboxd",
            "schedule": "0 0 * * 0"
        }
    ]
}